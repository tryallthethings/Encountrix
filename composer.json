{
  "name": "tryallthethings/encountrix",
  "description": "Encountrix WordPress plugin",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "scripts": {
    "lint": [
      "@lint:phpcs",
      "@lint:phpstan"
    ],
    "lint:fix": [
      "@lint:phpcbf"
    ],
    "lint:phpcs": "phpcs --standard=phpcs.xml",
    "lint:phpcbf": "phpcbf --standard=phpcs.xml",
    "lint:phpstan": "phpstan analyse --configuration=phpstan.neon.dist"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
